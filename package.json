{
  "name": "protondb-cli",
  "type": "module",
  "version": "1.15.0",
  "description": "CLI for the protondb project",
  "main": "dist/protondb-cli.js",
  "engines": {
    "node": ">=18.x",
    "npm": ">=8.19.2"
  },
  "scripts": {
    "start": "NODE_ENV=development npm run build && node dist/protondb-cli.js",
    "start:dev": "NODE_ENV=development tsx --watch protondb-cli.ts",
    "debug": "NODE_PATH=. node --inspect-brk=0.0.0.0:9229 ./protondb-cli.js",
    "build": "tsc && cp default.json dist/ && cp package.json dist/",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "lint:markdown": "markdownlint-cli2",
    "test": "npm run lint && npm run unit",
    "test:watch": "c8 --100 node --test --watch --loader esmock test",
    "test:keys": "npm start --prefix ./lib/core",
    "test:response": "npm start --prefix ./lib/fetcher",
    "unit": "c8 --100 node --test --import tsx/esm --loader esmock test/**/*.spec.ts",
    "unit:coverage": "node --test --experimental-test-coverage --import tsx/esm --loader esmock test/**/*.spec.ts",
    "test:coverage": "npm run lint && npm run unit:coverage",
    "prepare": "node -e \"try { require('husky').install() } catch (e) {if (e.code !== 'MODULE_NOT_FOUND') throw e}\"",
    "prepublishOnly": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jegj/protondb-cli.git"
  },
  "keywords": ["protondb", "cli", "steam"],
  "bin": {
    "protondb-cli": "dist/protondb-cli.js"
  },
  "license": "GPLv3",
  "dependencies": {
    "blessed": "0.1.81",
    "chalk": "5.3.0",
    "lowdb": "7.0.1",
    "node-html-parser": "6.1.13",
    "ora": "8.0.1",
    "p-map": "7.0.2",
    "undici": "^6.21.3",
    "yargs": "17.7.2"
  },
  "files": ["dist/", "default.json", "README.md", "LICENSE", "package.json"],
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@types/blessed": "^0.1.25",
    "@types/node": "^22.0.0",
    "@types/sinon": "^17.0.0",
    "@types/yargs": "^17.0.0",
    "c8": "^9.1.0",
    "esmock": "^2.6.4",
    "husky": "^8.0.3",
    "markdownlint-cli2": "^0.18.1",
    "sinon": "^17.0.1",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "bugs": {
    "url": "https://github.com/jegj/protondb-cli/issues"
  },
  "homepage": "https://github.com/jegj/protondb-cli#readme",
  "author": "Javier Galarza <jegj57@gmail.com>"
}
